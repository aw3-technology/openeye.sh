# OpenEye Perception Engine - Environment Variables

# Required for VLM mode (vlm_openai, vlm_gemini)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Gemini API key (for vlm_gemini plugin)
# GOOGLE_API_KEY=your-google-api-key-here

# Anthropic API key (for Claude VLM/LLM)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Nebius Token Factory (for Nebius VLM/LLM)
# NEBIUS_API_KEY=your-nebius-api-key-here

# OpenRouter (for free/paid model routing)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Tavily (for safety search action)
# TAVILY_API_KEY=your-tavily-api-key-here

# Camera index (default: 0 for built-in webcam)
CAMERA_INDEX=0
